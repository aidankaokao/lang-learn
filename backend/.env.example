# 後端「應用層」環境變數。複製成 backend/.env（不進版控）。
# 容器對外 port / labels 走「部署層」的根目錄 .env。

APP_ENV=dev

# ── 資料庫：初期 sqlite，之後 Cloud Run 換 postgres 只改這行 ──
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg://user:pass@db-host:5432/appdb

# ── JWT：正式環境務必換掉 ──
# 產一組：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# ── 預設管理員（啟動時自動建立，已存在則不動）──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# 是否開放自由註冊（false 時只有管理員能建帳號）
ALLOW_REGISTRATION=true

# ── 加密 LLM provider api_key 用的 Fernet 金鑰 ──
# 留空會從 JWT_SECRET 推導。正式環境建議固定一組：
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# 注意：LLM provider 不在這裡設定 —— 本專案有前端，改由使用者在設定頁註冊，
# 每人各自存自己的 key（見 reference/backend/llm-integration.md §5）。
