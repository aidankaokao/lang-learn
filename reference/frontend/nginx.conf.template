# 前端容器 nginx 設定【路由版・推薦】（起手檔）
# 把整個前端掛在 /<APP_ROUTE>/ 底下，讓內網與外網共用同一份 build：
#   內網：http://<ip>:<FRONTEND_PORT>/<APP_ROUTE>/
#   外網：https://<DNS>/<APP_ROUTE>/   （團隊 nginx 反代到上面那個 ip:port，路徑原樣轉發不改寫）
#
# 這是 nginx 官方 image 的「template」：容器啟動時會用 envsubst 把 ${APP_ROUTE} 代換成
# 環境變數的值（只代換有定義的 env 變數，$uri/$host 等 nginx 內建變數不受影響）。
# 放到專案的 frontend/nginx.conf.template；Dockerfile 要 COPY 到 /etc/nginx/templates/default.conf.template，
# 並在 docker-compose 給前端 service 設 environment: APP_ROUTE=${APP_ROUTE}。
# 說明見 frontend-backend-integration.md §6、deploy-guide.md 路由機制。
#
# 重要：這裡的 ${APP_ROUTE} 必須和 build 時的 VITE_BASE_PATH=/${APP_ROUTE}/ 一致（同一個 .env 的 APP_ROUTE 帶入），
# 換 route 要重新 build 前端 image。

server {
    listen 80;
    server_name _;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml+rss image/svg+xml;

    # 直接打根路徑時導到 route（方便內網 http://<ip>:<port>/ 進來）
    location = / {
        return 302 /${APP_ROUTE}/;
    }

    # 前端 SPA，掛在 /<route>/；dist 實體檔在 html 根，靠 alias 對應
    location /${APP_ROUTE}/ {
        alias /usr/share/nginx/html/;
        try_files $uri $uri/ /${APP_ROUTE}/index.html;
    }

    # API：/<route>/api/ 反代到後端，並把前綴改回後端實際的 /api/（proxy_pass 帶 URI 會做前綴替換）
    location /${APP_ROUTE}/api/ {
        proxy_pass http://backend:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE / 串流（LLM 逐字輸出）必要
        proxy_buffering off;
        proxy_read_timeout 3600s;
    }
}
