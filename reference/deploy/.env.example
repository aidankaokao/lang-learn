# 部署層環境變數範本（起手檔）。複製成專案【根目錄】的 .env（不進版控）。
# 這是給 docker-compose 讀的（對外 port + labels）；與後端應用層 backend/.env 分開。
# 說明見 deploy-guide.md §3。

# ── image / 網路命名（只改這裡；docker-compose.yaml 與 build.sh 都吃同一組）──
# image 會 build / 引用成 <IMAGE_PREFIX>-backend:<IMAGE_TAG> 與 <IMAGE_PREFIX>-frontend:<IMAGE_TAG>。
# 換新專案通常只要把 IMAGE_PREFIX 改成專案名即可。
IMAGE_PREFIX=myapp
IMAGE_TAG=0.1
NETWORK_NAME=myapp-network

# ── 路由名稱（內外網共用；見 deploy-guide.md 路由機制）──
# 前端掛在 /<APP_ROUTE>/ 底下：內網 http://<ip>:<FRONTEND_PORT>/<APP_ROUTE>/、外網 https://<DNS>/<APP_ROUTE>/
# 不含前後斜線，只填名稱。改動後前端 image 需重新 build（VITE_BASE_PATH 由它帶入）。
APP_ROUTE=myapp

# ── 對外 port（依實際情況改，不寫死在 compose）──
FRONTEND_PORT=8080
BACKEND_PORT=8000          # 僅開發期在 compose 打開 backend.ports 時用到

# ── labels（容器歸屬盤點）──
DEVELOPER_NAME=aidan
PROJECT_PATH=/home/aidan/projects/myapp
