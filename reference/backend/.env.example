# 後端「應用層」環境變數範本（起手檔）。複製成 backend/.env（不進版控）。
# 這是給 backend 程式（config.py）讀的；容器對外 port / labels 走「部署層」的 deploy/.env。
# 說明見 backend-conventions.md §5、llm-integration.md §2。

APP_ENV=dev

# ── 資料庫（見 database.md）：初期 sqlite，換 postgres 只改這行 ──
DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql+psycopg://user:pass@db-host:5432/appdb

# ── LLM（無前端專案才在這裡設；有前端則走設定頁註冊，見 llm-integration.md §0.1）──
# provider: ollama | openai
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.0

# 本地 Ollama
OLLAMA_BASE_URL=http://localhost:11434

# 外部 OpenAI 或本地 vLLM（vLLM 走 OpenAI 相容 API，只改 base_url）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
